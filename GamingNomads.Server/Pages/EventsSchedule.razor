@page  "/events"
@inherits EventsScheduleBase

<h1 class="page-title">Events Schedule</h1>

@if (EventCalendar == null)
{
        <p><em>Loading...</em></p>
}
else
{
    <div class="col-md-8">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Event</th>
                    <th>Dates</th>
                    <th>Games</th>
                    <th>Artemis</th>
                    <th>Laser Tag</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var show in EventCalendar)
                {
                <tr>
                    @if (show.Name.EndsWith("?"))
                    {
                        <td><a href="@show.URL" target="_blank">@show.Name.Replace("?", string.Empty) </a><span class="oi oi-calendar"></span></td>
                    }
                    else
                    {
                        <td><a href="@show.URL" target="_blank">@show.Name</a></td>
                    }
                    <td>@show.DatesText</td>
                    <td>@(show.Games ? "Yes" : "No")</td>
                    <td>@(show.Artemis ? "Yes" : "No")</td>
                    <td>@(show.LaserTag ? "Yes" : "No")</td>
                </tr>
                }
            </tbody>
        </table>
        <h4><span class="oi oi-calendar"></span> denotes events that have not been fully confirmed yet</h4>
    </div>
}